# ===========================================================================
#  MYSTORY CRM — variables d'environnement (modèle)
#  Copier en .env.local pour le dev ; en prod = variables Vercel.
#  NE JAMAIS committer de vraies valeurs. Ce fichier ne contient que des exemples.
# ===========================================================================

# --- Supabase (base + storage) ---------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...                 # clé service_role (secrète, back-office only)
SUPABASE_STORAGE_BUCKET=documents                # bucket privé des PDF

# --- Authentification (comptes + sessions) ---------------------------------
AUTH_SECRET=change-moi-32-caracteres-minimum     # secret de signature JWT
AUTH_COOKIE=mystory_session                       # nom du cookie de session
ACCESS_PASSWORD=                                  # mot de passe d'équipe (FILET, à retirer une fois les comptes individuels en place)
APP_URL=https://mystoryformation.fr               # base des liens dans les emails

# --- Email (SMTP IONOS) ----------------------------------------------------
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@mystoryformation.fr
SMTP_PASS=                                         # mot de passe de la boîte (secret)
SMTP_FROM=contact@mystoryformation.fr
SMTP_REPLY_TO=contact@mystoryformation.fr
BACKUP_EMAIL=contact@mystoryformation.fr          # destinataire de la sauvegarde hebdo (défaut: contact@)

# --- DocuSeal (signature électronique) -------------------------------------
DOCUSEAL_BASE_URL=https://docuseal.xxx
DOCUSEAL_API_KEY=
DOCUSEAL_OF_EMAIL=contact@mystoryformation.fr     # signataire « Organisme »
DOCUSEAL_WEBHOOK_HEADER=X-Docuseal-Signature       # nom de l'en-tête de vérification du webhook
DOCUSEAL_WEBHOOK_HEADER_VALUE=                     # valeur attendue de cet en-tête
DOCUSEAL_WEBHOOK_SECRET=                           # secret HMAC (si utilisé)
DOCUSEAL_WEBHOOK_TOKEN=                            # jeton alternatif (si utilisé)

# --- Identité visuelle des documents ---------------------------------------
MYSTORY_CACHET_URL=                                # URL du cachet MYSTORY (3 sites, sans Paris)
MYSTORY_OF_SIGNATURE_URL=                          # URL de la signature de l'organisme

# --- Slack (notif messages prospects, optionnel) ---------------------------
SLACK_WEBHOOK_URL=                                 # vide = pas de notif Slack (messages stockés + email quand même)
